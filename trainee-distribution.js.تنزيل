                cell.style.setProperty('font-size', size + 'px', 'important');

                // Absolute strict single line
                cell.style.setProperty('white-space', 'nowrap', 'important');
                cell.style.setProperty('word-break', 'keep-all', 'important');
                cell.style.setProperty('overflow', 'hidden', 'important');

                // Decrease size until content fits both vertically and horizontally
                // Allow 1px tolerance
                while ((cell.scrollHeight > cell.clientHeight + 1 || cell.scrollWidth > cell.clientWidth + 1) && size > 5) {
                    size -= 0.5;
                    cell.style.setProperty('font-size', size + 'px', 'important');
