            document.querySelectorAll('.row-height-circle').forEach(circle => {
                circle.classList.remove('active');
                circle.style.background = 'var(--bg-header)';
                circle.style.borderColor = 'var(--border-dark)';
                if (parseInt(circle.dataset.level) === level) {
                    circle.classList.add('active');
                    circle.style.background = 'var(--accent-green)';
                    circle.style.borderColor = 'var(--accent-green)';
                }
            });

            // Map levels to height values (px) AND base font sizes AND padding AND target row capacity
            const configMap = {
                1: { height: 22,   fontSize: 8,    padding: '0px 3px', maxRows: 35, label: '35 صف (مضغوط جداً)' },
                2: { height: 26,   fontSize: 9,    padding: '1px 3px', maxRows: 30, label: '30 صف (مضغوط)' },
                3: { height: 31.5, fontSize: 10,   padding: '2px 4px', maxRows: 25, label: '25 صف (متوسط)' },
                4: { height: 39,   fontSize: 11,   padding: '4px 6px', maxRows: 20, label: '20 صف (مريح)' },
                5: { height: 49,   fontSize: 12,   padding: '6px 8px', maxRows: 15, label: '15 صف (واسع)' }
            };

            const config = configMap[level] || configMap[3];
            if (labelEl) labelEl.textContent = config.label;

            // Update global base font size
            currentBaseFontSize = config.fontSize;

            // Set CSS variable
            document.documentElement.style.setProperty('--print-row-height', config.height + 'px');

            // Set the trainees per page input to match the slider's max capacity
            const tppInput = document.getElementById('traineesPerPage');
            let needRegenerate = false;
            if (tppInput && tppInput.value !== config.maxRows.toString()) {
                tppInput.value = config.maxRows;
                // Only trigger regenerate if we have already rendered reports
                if (document.querySelectorAll('.report-page').length > 0) {
                    needRegenerate = true;
                }
            }

            // FORCE inline styles on all cells to ensure print rendering respects it
            const applyStyles = () => {
                const cells = document.querySelectorAll('.report-table td, .report-table th');
                cells.forEach(cell => {
                    // Skip the main header TH which contains the logo and info
                    if (cell.colSpan > 2) return;
                    
                    cell.style.setProperty('box-sizing', 'border-box', 'important');
                    cell.style.setProperty('padding', config.padding, 'important');
                    // Use larger line-height for Arabic text to prevent vertical overlap
                    cell.style.setProperty('line-height', (config.fontSize * 1.4) + 'px', 'important');
                    cell.style.setProperty('white-space', 'nowrap', 'important');
                    cell.style.setProperty('word-break', 'keep-all', 'important');
                    cell.style.setProperty('overflow', 'hidden', 'important');
                    
                    if (cell.tagName === 'TD') {
                        cell.style.setProperty('height', config.height + 'px', 'important');
                    } else if (cell.tagName === 'TH') {
                        // Headers should also be compact
                        cell.style.setProperty('height', (config.height + 2) + 'px', 'important');
                        cell.style.setProperty('font-size', config.fontSize + 'px', 'important');
                    }
                });
                
                // Also explicitly set TR heights
                const rows = document.querySelectorAll('.report-table tbody tr');
                rows.forEach(row => {
                    row.style.setProperty('height', config.height + 'px', 'important');
                });

                // Trigger auto-fit after a brief delay
                setTimeout(() => {
                    autoFitText();
                }, 50);
            };

            if (needRegenerate) {
                // Save setting first
                currentRowHeightLevel = level;
                savePrintSettings();
                // Regenerate reports to apply new pagination, then apply styles
                generateReports();
                setTimeout(applyStyles, 200); // wait for generateReports to render
            } else {
                applyStyles();
                currentRowHeightLevel = level;
                savePrintSettings();
            }
        }

        function savePrintSettings() {
