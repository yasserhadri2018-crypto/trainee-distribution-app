                    <tr><th colspan="${excelColCount}">توزيع المتدربين على لجان الاختبارات</th></tr>
                    <tr><td>الكلية / الوحدة:</td><td colspan="${excelColCount - 1}">${collegeName}</td></tr>
                    <tr><td>الفصل التدريبي:</td><td colspan="${excelColCount - 1}">${semester}</td></tr>
                    <tr><td>المقرر:</td><td colspan="${excelColCount - 1}">${courseNames}</td></tr>
                    ${instructorInfoRow}
                    <tr><td>اسم اللجنة:</td><td colspan="${excelColCount - 1}" data-committee-name="true"></td></tr>
                    <tr><td>رقم القاعة:</td><td colspan="${excelColCount - 1}" data-room-number="true"></td></tr>
                    <tr><td colspan="${excelColCount}"></td></tr>
                    <tr>
                        <th>#</th>
                        <th>رقم المتدرب</th>
                        <th>اسم المتدرب</th>
                        <th>الرقم المرجعي</th>
                        ${showInstructorCol ? '<th>المدرب</th>' : ''}
                        <th>توقيع المتدرب</th>
                    </tr>
                `;
            } else {
                // Full header with all columns
                thead.innerHTML = `
                    <tr><th colspan="${excelColCount}">توزيع المتدربين على لجان الاختبارات</th></tr>
                    <tr><td>الكلية / الوحدة:</td><td colspan="5">${collegeName}</td><td colspan="2" data-logo="true"></td></tr>
                    <tr><td>الفصل التدريبي:</td><td colspan="5">${semester}</td><td colspan="2" data-logo="true"></td></tr>
                    ${instructorInfoRow}
                    <tr><td>اسم اللجنة:</td><td colspan="5" data-committee-name="true"></td><td colspan="2" data-logo="true"></td></tr>
                    <tr><td>رقم القاعة:</td><td colspan="5" data-room-number="true"></td><td colspan="2"></td></tr>
                    <tr><td colspan="${excelColCount}"></td></tr>
                    <tr>
                        <th>اللجنة</th>
                        <th>#</th>
                        <th>رقم المتدرب</th>
                        <th>اسم المتدرب</th>
                        <th>اسم المقرر</th>
                        <th>الرقم المرجعي</th>
                        ${showInstructorCol ? '<th>المدرب</th>' : ''}
                        <th>توقيع المتدرب</th>
                    </tr>
                `;
            }
            tempTable.appendChild(thead);

            // Add data from all report tables
            const tbody = document.createElement('tbody');
            let rowCount = 0;

            reportPages.forEach((page, pageIdx) => {
                // Extract the (possibly edited) committee name and remove page suffix like "(صفحة 1 من 2)"
                let roomName = page.querySelector('.committee-name-text')?.textContent?.trim() || `لجنة ${pageIdx + 1}`;
                roomName = roomName.replace(/\s*\(صفحة\s*\d+\s*من\s*\d+\)/, '').trim();
                // Direct-child tbody rows only — avoids picking up the rows of the nested
                // signature table inside <tfoot> (which would leak into the data as garbage rows).
                const rows = page.querySelectorAll('.report-table > tbody > tr');
                // Expected number of data columns in a report row (incl. the trailing signature cell)
                const expectedReportCols = (hideExtraCols ? 6 : 7) - (showInstructorCol ? 0 : 1);

                rows.forEach(row => {
                    const cells = row.querySelectorAll('td');
                    // Report rows already match the active column set (instructor/course columns
                    // may be absent). Copy every data cell except the report's trailing (empty)
                    // signature cell, optionally prepend the committee name, then append a blank
                    // signature cell for Excel.
                    if (cells.length >= expectedReportCols) {
                        const dataCells = Array.from(cells).slice(0, cells.length - 1)
                            .map(c => c.textContent || '');
                        const rowCells = hideExtraCols ? dataCells : [roomName, ...dataCells];
                        rowCells.push(' ');
                        const newRow = document.createElement('tr');
                        newRow.innerHTML = rowCells.map(t => `<td>${t}</td>`).join('');
                        tbody.appendChild(newRow);
                        rowCount++;
                    }
                });
            });
            tempTable.appendChild(tbody);

            if (rowCount === 0) {
                showToast('لا توجد بيانات للتصدير.', 'warning');
                return;
            }

            document.body.appendChild(tempTable);

            // Load ExcelJS library and export
            if (typeof ExcelJS === 'undefined') {
                const script = document.createElement('script');
                script.src = 'https://cdn.jsdelivr.net/npm/exceljs@4.4.0/dist/exceljs.min.js';
                script.onload = () => {
                    generateExcelFromTable(tempTable, courseNames);
                };
                script.onerror = () => {
                    showToast('فشل تحميل مكتبة Excel. تحقق من اتصال الإنترنت.', 'error');
                    document.body.removeChild(tempTable);
                };
                document.head.appendChild(script);
            } else {
                generateExcelFromTable(tempTable, courseNames);
            }
        }

        async function generateExcelFromTable(table, courseNames) {
            try {
                const hideExtraCols = table.dataset.hideExtraCols === 'true';
                const showInstructorCol = table.dataset.showInstructorCol !== 'false';
                const colCount = (hideExtraCols ? 6 : 8) - (showInstructorCol ? 0 : 1);
                // Number of label/value info rows: base (college, semester, committee, room) = 4,
                // plus a course row in hide mode, plus an instructor row in single-instructor mode.
                const infoRowCount = 4 + (hideExtraCols ? 1 : 0) + (showInstructorCol ? 0 : 1);
                // Header rows = title + info rows + separator + column header
                const headerRowCount = infoRowCount + 3;
                // One note row is prepended above the table; it is kept OUT of the print area.
                const topOffset = 1;
                const noteRowIdx = 0;
                const titleRowIdx = topOffset; // title sits just below the note
                // Header-relative indices (committee = second-to-last info row, room = last info row)
                const committeeNameRowIdx = infoRowCount - 1;
                const roomNumberRowIdx = infoRowCount;
                // sheetData-relative indices (after the note row is prepended)
                const separatorRowIdx = topOffset + headerRowCount - 2;
                const colHeaderRowIdx = topOffset + headerRowCount - 1;
                const infoRowStart = topOffset + 1;
                const infoRowEnd = topOffset + infoRowCount;

                // Group data by committee
                const committees = new Map(); // Map: committeeName -> [rows]
                const headerRows = [];

                const allRows = table.querySelectorAll('tr');
                allRows.forEach((row, rowIndex) => {
                    const cells = row.querySelectorAll('th, td');
                    const rowData = [];
                    for (let i = 0; i < colCount; i++) {
                        const cellText = cells[i]?.textContent?.trim() || ' ';
                        rowData.push(cellText === '' ? ' ' : cellText);
                    }

                    if (rowIndex < headerRowCount) {
                        headerRows.push(rowData);
                    } else {
                        if (hideExtraCols) {
                            // No committee column - we need to figure out which committee this row belongs to
                            // We'll assign it later using committeeDistribution counts
                            if (!committees.has('__all__')) {
                                committees.set('__all__', []);
                            }
                            committees.get('__all__').push(rowData);
                        } else {
                            // Data row - group by committee (column 0)
                            const committeeName = rowData[0];
                            if (!committees.has(committeeName)) {
                                committees.set(committeeName, []);
                            }
                            committees.get(committeeName).push(rowData);
                        }
                    }
                });

                // In hide mode, redistribute rows by committee using committeeDistribution
                if (hideExtraCols && committees.has('__all__')) {
                    const allDataRows = committees.get('__all__');
                    committees.delete('__all__');
                    
                    const activeCommittees = committeeDistribution.filter(c => c.count > 0);
                    let rowStart = 0;
                    activeCommittees.forEach(c => {
                        const chunk = allDataRows.slice(rowStart, rowStart + c.count);
                        if (chunk.length > 0) {
                            committees.set(c.name, chunk);
                        }
                        rowStart += c.count;
                    });
                }

                // Try to load the institution logo as a base64 data URL (optional - export works without it)
                let logoBase64 = null;
                let logoError = '';
                // Method 1: fetch the file directly (works when served over http/https)
                try {
                    const logoResp = await fetch('pic/logo.png');
                    if (logoResp.ok) {
                        const logoBlob = await logoResp.blob();
                        logoBase64 = await new Promise(resolve => {
                            const reader = new FileReader();
                            reader.onload = () => resolve(reader.result);
                            reader.onerror = () => resolve(null);
                            reader.readAsDataURL(logoBlob);
                        });
                        if (!logoBase64) logoError = 'تعذّرت قراءة ملف الشعار';
                    } else {
                        logoError = `لم يُعثر على الملف (HTTP ${logoResp.status})`;
                    }
                } catch (e) {
                    logoError = e.message || 'فشل جلب الملف';
                }
                // Method 2 (fallback): reuse the logo already shown in the report via canvas
                if (!logoBase64) {
                    try {
                        const imgEl = document.querySelector('.report-page img[src*="logo"]') ||
                                      document.querySelector('img[src*="logo"]');
                        if (imgEl && imgEl.complete && imgEl.naturalWidth > 0) {
                            const canvas = document.createElement('canvas');
                            canvas.width = imgEl.naturalWidth;
                            canvas.height = imgEl.naturalHeight;
                            canvas.getContext('2d').drawImage(imgEl, 0, 0);
                            logoBase64 = canvas.toDataURL('image/png');
                            logoError = '';
                        }
                    } catch (e) {
                        // Canvas can be tainted when running from file:// - keep the original error
                    }
                }
                // Tell the user explicitly if the logo could not be embedded
                if (!logoBase64) {
                    showToast(`⚠️ لم يُدرج الشعار في ملف Excel${logoError ? ` (${logoError})` : ''}. تأكد من وجود الملف pic/logo.png وأن الموقع يعمل عبر خادم وليس فتح الملف مباشرة.`, 'warning');
                }

                // Define styles (ARGB - ExcelJS requires the leading alpha byte)
                const thinBorder = {
                    top: { style: 'thin', color: { argb: 'FF333333' } },
                    bottom: { style: 'thin', color: { argb: 'FF333333' } },
                    left: { style: 'thin', color: { argb: 'FF333333' } },
                    right: { style: 'thin', color: { argb: 'FF333333' } }
                };
                const solidFill = (argb) => ({ type: 'pattern', pattern: 'solid', fgColor: { argb } });

                // Create workbook (RTL views are set per-worksheet below)
                const workbook = new ExcelJS.Workbook();

                // Load the logo once as an HTMLImageElement so we can both measure its natural
                // aspect ratio and pre-composite it (centered) onto a transparent canvas.
                let logoImg = null;
                let logoAspect = 311 / 370; // fallback (current logo) width / height
                if (logoBase64) {
                    try {
                        logoImg = await new Promise(resolve => {
                            const im = new Image();
                            im.onload = () => resolve(im);
                            im.onerror = () => resolve(null);
                            im.src = logoBase64;
                        });
                        if (logoImg && logoImg.naturalHeight > 0) {
                            logoAspect = logoImg.naturalWidth / logoImg.naturalHeight;
                        }
                    } catch (e) { /* keep fallback aspect */ }
                }

                // ---- Logo block geometry (identical for every committee sheet) -----------------
                // Fixed column widths per role; the last two columns of the info rows are reserved
                // as an empty merged block that will hold the logo.
                // Full mode: [اللجنة, #, رقم المتدرب, اسم المتدرب, اسم المقرر, الرقم المرجعي, المدرب, توقيع]
                // Hide mode: [#, رقم المتدرب, اسم المتدرب, الرقم المرجعي, المدرب, توقيع]
                const colWidths = hideExtraCols
                    ? [5, 13, 28, 14, 22, 16]
                    : [16, 5, 13, 26, 22, 14, 20, 16];
                // Drop the instructor column width (second-to-last) in single-instructor mode
                if (!showInstructorCol) colWidths.splice(colWidths.length - 2, 1);
                const lastCol = colCount - 1;
                const logoFirstCol = lastCol - 1;   // first of the two reserved logo columns
                const valueLastCol = lastCol - 2;   // info values stop just before the logo block
                const infoRowHeightPt = 18;         // fixed so the block height is deterministic

                // Excel cell-size -> pixel conversions (Calibri 11: width 8.43 -> 64px; 1pt -> 96/72px)
                const pxW = (w) => Math.round(w * 7 + 5);
                const pxH = (pt) => Math.round(pt * 96 / 72);
                const blockWidthPx = colWidths
                    .slice(logoFirstCol, lastCol + 1)
                    .reduce((sum, w) => sum + pxW(w), 0);
                const blockHeightPx = (infoRowEnd - infoRowStart + 1) * pxH(infoRowHeightPt);

                // Pre-composite the logo, centered, onto a transparent canvas the EXACT size of the
                // reserved block. Centering is baked into the image itself, so it stays centered no
                // matter how Excel mirrors the RTL column axis. Because the canvas has the same
                // aspect ratio as the block, the two-cell anchor below fills the block with no
                // stretching of the logo (see LOGO_EXCEL_ATTEMPTS.md, idea ج).
                let composedLogoImageId = null;
                if (logoImg) {
                    const scale = 3; // render at 3x for crisp printing; displayed at the block size
                    const canvas = document.createElement('canvas');
                    canvas.width = blockWidthPx * scale;
                    canvas.height = blockHeightPx * scale;
                    const ctx = canvas.getContext('2d');
                    ctx.imageSmoothingEnabled = true;
                    ctx.imageSmoothingQuality = 'high';

                    // Fit the logo inside the block at its true aspect ratio (capped for consistency)
                    const maxLogoH = 84;
                    const padX = 8;
                    let logoH = Math.min(blockHeightPx - 12, maxLogoH);
                    let logoW = logoH * logoAspect;
                    if (logoW > blockWidthPx - 2 * padX) {
                        logoW = blockWidthPx - 2 * padX;
                        logoH = logoW / logoAspect;
                    }
                    const logoX = (blockWidthPx - logoW) / 2;
                    const logoY = (blockHeightPx - logoH) / 2;
                    ctx.drawImage(logoImg, logoX * scale, logoY * scale, logoW * scale, logoH * scale);

                    composedLogoImageId = workbook.addImage({
                        base64: canvas.toDataURL('image/png'),
                        extension: 'png'
                    });
                }

                // Create a sheet for each committee
                let sheetIndex = 0;
                committees.forEach((rows, committeeName) => {
                    sheetIndex++;

                    // Clone header rows and customize for this committee
                    const customHeaderRows = headerRows.map((row, rowIdx) => {
                        const newRow = [...row];
                        if (rowIdx === committeeNameRowIdx) {
                            // Fill with committee name
                            newRow[1] = committeeName;
                        } else if (rowIdx === roomNumberRowIdx) {
                            // Fill with room number
                            const committeeIdx = committeeDistribution.findIndex(c => c.name === committeeName);
                            const roomObj = committeeIdx >= 0 ? committeeRooms[committeeIdx] : null;
                            newRow[1] = roomObj?.room || '';
                        }
                        return newRow;
                    });

                    // A note row above the table (excluded from the print area below) explaining
                    // how to auto-fit columns, plus the customized headers + committee rows.
                    const noteRow = Array(colCount).fill('');
                    noteRow[0] = '💡 لضبط عرض الأعمدة: انقر على المثلث أعلى يمين الورقة لتحديد كل الخلايا، ثم انقر نقراً مزدوجاً على الحدّ الفاصل بين أي عمودين. (هذا السطر لا يظهر عند الطباعة)';
                    const sheetData = [noteRow, ...customHeaderRows, ...rows];

                    // Add signature section at end
                    const dataEndRow = sheetData.length;

                    // 2 empty rows + 1 spacer row
                    const emptyRow = Array(colCount).fill('');
                    sheetData.push([...emptyRow]);
                    sheetData.push([...emptyRow]);
                    sheetData.push([...emptyRow]);

                    // Signature labels and values — split colCount into 3 groups (one per signer).
                    // e.g. 8→3-2-3, 7→3-1-3, 6→2-2-2, 5→2-1-2.
                    const sigEdge = Math.ceil(colCount / 3);
                    const sigGroupSizes = [sigEdge, colCount - 2 * sigEdge, sigEdge];
                    const sigLabelsList = ['المراقب الأول:', 'المراقب الثاني:', 'رئيس اللجنة:'];
                    const sigGroups = [];
                    const sigLabelRow = Array(colCount).fill('');
                    const sigSignRow = Array(colCount).fill('');
                    let sigCol = 0;
                    sigGroupSizes.forEach((gsize, gi) => {
                        sigLabelRow[sigCol] = sigLabelsList[gi];
                        sigSignRow[sigCol] = 'التوقيع:';
                        sigGroups.push([sigCol, sigCol + gsize - 1]);
                        sigCol += gsize;
                    });
                    sheetData.push(sigLabelRow);
                    sheetData.push(sigSignRow);

                    // Sheet name (max 31 chars, clean invalid chars)
                    let sheetName = committeeName.substring(0, 28).replace(/[\\/*?:\[\]]/g, '');
                    if (sheetName.trim() === '') sheetName = `لجنة ${sheetIndex}`;

                    const ws = workbook.addWorksheet(sheetName, {
                        views: [{ rightToLeft: true }],
                        pageSetup: {
                            // Fit all columns onto a single page width; let height span as needed
                            fitToPage: true,
                            fitToWidth: 1,
                            fitToHeight: 0,
                            orientation: 'portrait',
                            paperSize: 9, // A4
                            horizontalCentered: true,
                            margins: { left: 0.3, right: 0.3, top: 0.4, bottom: 0.4, header: 0.2, footer: 0.2 }
                        }
                    });

                    // Write all rows
                    sheetData.forEach(rowArr => ws.addRow(rowArr));

                    // Apply styles cell-by-cell (R, C are 0-based; ExcelJS cells are 1-based)
                    for (let R = 0; R < sheetData.length; R++) {
                        for (let C = 0; C < colCount; C++) {
                            const cell = ws.getCell(R + 1, C + 1);

                            if (R === noteRowIdx) {
                                // Instruction note (above the print area) - distinct amber styling
                                cell.fill = solidFill('FFFFF3CD');
                                cell.font = { size: 10, bold: true, color: { argb: 'FF8A6D00' } };
                                cell.alignment = { horizontal: 'center', vertical: 'middle', readingOrder: 'rtl', wrapText: true };
                            } else if (R === titleRowIdx) {
                                // Title
                                cell.fill = solidFill('FFD4A017');
                                cell.font = { color: { argb: 'FFFFFFFF' }, bold: true, size: 14 };
                                cell.alignment = { horizontal: 'center', vertical: 'middle', readingOrder: 'rtl' };
                                cell.border = thinBorder;
                            } else if (R >= infoRowStart && R <= infoRowEnd) {
                                // Info rows (label + value)
                                const isLabel = C === 0;
                                cell.fill = solidFill(isLabel ? 'FFE5E7EB' : 'FFFFFFFF');
                                cell.font = { size: 11, bold: isLabel };
                                cell.alignment = { horizontal: 'right', vertical: 'middle', readingOrder: 'rtl', wrapText: true };
                                cell.border = thinBorder;
                            } else if (R === separatorRowIdx) {
                                // Blank separator row
                                cell.fill = solidFill('FFFFFFFF');
                            } else if (R === colHeaderRowIdx) {
                                // Column headers
                                cell.fill = solidFill('FF1E3A5F');
                                cell.font = { color: { argb: 'FFFFFFFF' }, bold: true, size: 11 };
                                cell.alignment = { horizontal: 'center', vertical: 'middle', readingOrder: 'rtl' };
                                cell.border = thinBorder;
                            } else if (R < dataEndRow) {
                                // Data rows (alternating fill); wrap long names instead of clipping
                                const isEven = (R - colHeaderRowIdx) % 2 === 0;
                                cell.fill = solidFill(isEven ? 'FFF9FAFB' : 'FFFFFFFF');
                                cell.font = { size: 10 };
                                cell.alignment = { horizontal: 'center', vertical: 'middle', readingOrder: 'rtl', wrapText: true };
                                cell.border = thinBorder;
                            } else if (R === dataEndRow + 2) {
                                // Spacer row - no borders
                                cell.fill = solidFill('FFFFFFFF');
                            } else if (R === dataEndRow + 3) {
                                // Signature labels
                                cell.font = { bold: true, size: 11 };
                                cell.alignment = { horizontal: 'right', vertical: 'middle', readingOrder: 'rtl' };
                                cell.border = thinBorder;
                            } else if (R === dataEndRow + 4) {
                                // Empty signature row
                                cell.alignment = { horizontal: 'right', vertical: 'middle', readingOrder: 'rtl' };
                                cell.border = thinBorder;
                            }
                        }
                    }

                    // Row heights: note, title, and column-header rows
                    ws.getRow(noteRowIdx + 1).height = 30;
                    ws.getRow(titleRowIdx + 1).height = 26;
                    ws.getRow(colHeaderRowIdx + 1).height = 20;

                    // Apply the fixed column widths (defined once above). Long-text columns wrap
                    // instead of being clipped (alignment set further up).
                    for (let C = 0; C < colCount; C++) {
                        ws.getColumn(C + 1).width = colWidths[C] || 14;
                    }

                    // Merges (convert 0-based ranges to ExcelJS 1-based row/col).
                    // lastCol / logoFirstCol / valueLastCol are defined once above the loop; the last
                    // two columns of the info rows are reserved as an empty merged block for the logo.
                    const merge = (r1, c1, r2, c2) => ws.mergeCells(r1 + 1, c1 + 1, r2 + 1, c2 + 1);

                    merge(noteRowIdx, 0, noteRowIdx, lastCol);        // Instruction note (full width)
                    merge(titleRowIdx, 0, titleRowIdx, lastCol);      // Title (full width)
                    for (let r = infoRowStart; r <= infoRowEnd; r++) {
                        merge(r, 1, r, valueLastCol);                 // Info value cells
                    }
                    merge(separatorRowIdx, 0, separatorRowIdx, lastCol); // Separator (full width)
                    merge(infoRowStart, logoFirstCol, infoRowEnd, lastCol); // Reserved logo block

                    // Signature merges — one merged block per signer group (labels + signature rows)
                    sigGroups.forEach(([c1, c2]) => {
                        merge(dataEndRow + 3, c1, dataEndRow + 3, c2);
                        merge(dataEndRow + 4, c1, dataEndRow + 4, c2);
                    });

                    // Place the pre-composited logo so it fills the reserved merged block exactly.
                    // The logo is already centered *inside* the image (with transparent padding) and
                    // the image shares the block's aspect ratio, so a two-cell anchor on integer cell
                    // boundaries (no fractional offsets) fills the block without stretching the logo
                    // and keeps it centered regardless of the sheet's RTL direction.
                    if (composedLogoImageId !== null) {
                        // Fix the info-row heights so the block matches the composited image's size.
                        for (let r = infoRowStart; r <= infoRowEnd; r++) {
                            ws.getRow(r + 1).height = infoRowHeightPt;
                        }
                        ws.addImage(composedLogoImageId, {
                            tl: { col: logoFirstCol, row: infoRowStart },
                            br: { col: lastCol + 1, row: infoRowEnd + 1 },
                            editAs: 'oneCell'
                        });
                    }

                    // Keep the instruction note out of the print area (start printing at the title row)
                    ws.pageSetup.printArea = `A${titleRowIdx + 1}:${ws.getColumn(colCount).letter}${sheetData.length}`;
                });

                // Export file (ExcelJS writes a buffer; trigger download via a Blob)
                const fileNameBase = courseNames.length > 50 ? 'توزيع_المتدربين' : `توزيع_${courseNames.replace(/[|\/\\:*?"<>]/g, '_').substring(0, 50)}`;
                const buffer = await workbook.xlsx.writeBuffer();
                const blob = new Blob([buffer], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `${fileNameBase}.xlsx`;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                setTimeout(() => URL.revokeObjectURL(url), 1000);

                showToast(`تم تصدير ${committees.size} لجنة في ملف Excel`, 'success');
            } catch (err) {
                console.error('Excel export error:', err);
                showToast('حدث خطأ في التصدير: ' + err.message, 'error');
            } finally {
                document.body.removeChild(table);
            }
        }

        // Keyboard shortcuts
        document.addEventListener('keydown', (e) => {
            // Don't trigger navigation when typing in input fields
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

            // For RTL: Left arrow = next (forward), Right arrow = previous (back)
            if (e.key === 'ArrowLeft') nextStep();
            if (e.key === 'ArrowRight') previousStep();
            if (e.ctrlKey && e.key === 'p') { e.preventDefault(); window.print(); }
        });

