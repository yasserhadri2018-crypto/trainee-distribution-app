            const tppVal = document.getElementById('traineesPerPage')?.value || '';
            const sigVal = document.getElementById('showSignatureFooter')?.checked ?? true;
            const hideColsVal = document.getElementById('hideExtraColumns')?.checked ?? false;
            saveToIndexedDB({
                rowHeightLevel: currentRowHeightLevel,
                sortOrder: sortVal,
                traineesPerPage: tppVal,
                showSignatureFooter: sigVal,
                hideExtraColumns: hideColsVal
            }, 'userPrintSettings');
        }



        function exportToExcel() {
