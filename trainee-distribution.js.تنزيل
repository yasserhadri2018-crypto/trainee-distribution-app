            const summaryEl = document.getElementById('statusSummaryStep2');
            if (summaryEl) {
                summaryEl.innerHTML = unknown > 0
                    ? `<span style="color:#f59e0b; font-weight:600;">يوجد ${unknown} متدرب غير مصنف - يجب تصنيف الحالات قبل المتابعة</span>`
