        function updateStatusFilter() {
            sortOrder = document.querySelector('input[name="sortOrder"]:checked')?.value || 'traineeId';
        }

        // ===== Step 4: Instructor Selection =====
        const INSTRUCTOR_UNSPECIFIED = 'غير محدد';

        // Normalize an instructor cell: blank/whitespace becomes the "unspecified" pseudo-instructor
        function normalizeInstructor(v) {
            const s = (v == null ? '' : String(v)).trim();
            return s === '' ? INSTRUCTOR_UNSPECIFIED : s;
        }

        // Escape a value so it is safe inside onclick="fn('...')"
        function escInstructor(s) {
            return String(s).replace(/\\/g, '\\\\').replace(/'/g, "\\'");
        }

        // {name, count} per distinct instructor across the selected courses (respecting status filter)
        function getCourseInstructorCounts() {
            const counts = new Map();
            selectedCourses.forEach(key => {
                const [code, scheduleType] = key.split('|');
                sf01Data
                    .filter(r =>
                        r['المقرر'] === code &&
                        r['نوع الجدولة'] === scheduleType &&
                        includedStatuses.includes(r['حالة تسجيل'] || 'غير محدد'))
                    .forEach(r => {
                        const name = normalizeInstructor(r['المدرب']);
                        counts.set(name, (counts.get(name) || 0) + 1);
                    });
            });
            return [...counts.entries()]
                .map(([name, count]) => ({ name, count }))
                .sort((a, b) => a.name.localeCompare(b.name, 'ar'));
        }

        // All instructor names available for the current course selection
        function getAllInstructors() {
            return getCourseInstructorCounts().map(i => i.name);
        }

        // Instructors currently kept (available minus the ones the user excluded)
        function getActiveInstructors() {
            return getAllInstructors().filter(name => !excludedInstructors.includes(name));
        }

        // Row-level filter shared by preview / committee / reports
        function isInstructorIncluded(r) {
            if (!excludedInstructors.length) return true;
            return !excludedInstructors.includes(normalizeInstructor(r['المدرب']));
        }

        // True when the report should drop the instructor column and show the name in the header
        function isSingleInstructor() {
            return getActiveInstructors().length === 1;
        }

        function populateStep4() {
            // Drop any exclusions that no longer exist for the current course selection
            const all = getAllInstructors();
            excludedInstructors = excludedInstructors.filter(name => all.includes(name));
            const filterInput = document.getElementById('instructorFilter');
            if (filterInput) filterInput.oninput = renderInstructors;
            renderInstructors();
        }

        function renderInstructors() {
            const listEl = document.getElementById('instructorsList');
            if (!listEl) return;

            const instructors = getCourseInstructorCounts();
            const filterText = (document.getElementById('instructorFilter')?.value || '').toLowerCase();
            const filtered = filterText
                ? instructors.filter(i => i.name.toLowerCase().includes(filterText))
                : instructors;

            // Summary bar
            const summaryBar = document.getElementById('instructorSummaryBar');
            const total = instructors.length;
            const includedCount = instructors.filter(i => !excludedInstructors.includes(i.name)).length;
            if (summaryBar) {
                summaryBar.style.display = total > 0 ? 'block' : 'none';
                document.getElementById('instructorIncludedCount').textContent = includedCount;
                document.getElementById('instructorTotalCount').textContent = total;
                document.getElementById('resetInstructorsBtn').style.display =
                    excludedInstructors.length > 0 ? 'inline-flex' : 'none';
            }

            if (total === 0) {
                listEl.innerHTML = `<div style="color:var(--text-muted); padding:20px; text-align:center; width:100%;">لا يوجد مدربون للمقررات المختارة.</div>`;
                return;
            }

            listEl.innerHTML = filtered.map(i => {
                const excluded = excludedInstructors.includes(i.name);
                return `
                    <div onclick="toggleInstructor('${escInstructor(i.name)}')"
                         style="cursor:pointer; user-select:none; display:inline-flex; align-items:center; gap:8px; padding:10px 14px; border-radius:10px;
                                border:1px solid ${excluded ? 'var(--border-dark)' : 'var(--accent-green)'};
                                background:${excluded ? 'var(--bg-header)' : 'rgba(16,185,129,0.12)'};
                                opacity:${excluded ? '0.55' : '1'}; transition:all 0.15s ease;">
                        <i data-lucide="${excluded ? 'user-x' : 'user-check'}" style="width:16px; height:16px; color:${excluded ? 'var(--text-muted)' : 'var(--accent-green)'};"></i>
                        <span style="color:var(--text-light); font-weight:600; font-size:13px; ${excluded ? 'text-decoration:line-through;' : ''}">${i.name}</span>
                        <span style="background:${excluded ? 'var(--border-dark)' : 'var(--accent-gold)'}; color:${excluded ? 'var(--text-muted)' : '#000'}; padding:2px 8px; border-radius:10px; font-size:11px; font-weight:700;">${i.count}</span>
                    </div>`;
            }).join('');

            if (typeof lucide !== 'undefined') lucide.createIcons();
        }

        function toggleInstructor(name) {
            const idx = excludedInstructors.indexOf(name);
            if (idx === -1) {
                // Keep at least one instructor active
                if (getActiveInstructors().length <= 1) {
                    showToast('يجب الإبقاء على مدرب واحد على الأقل', 'warning');
                    return;
                }
                excludedInstructors.push(name);
            } else {
                excludedInstructors.splice(idx, 1);
            }
            // The included population changed -> rebuild committee distribution downstream
            committeeDistribution = [];
            renderInstructors();
            updateStepClickability();
        }

        function resetInstructors() {
            excludedInstructors = [];
            committeeDistribution = [];
            renderInstructors();
            updateStepClickability();
        }

        // Step 5: Committee Count
        function populateStep5() {
            // Calculate total trainees for selected courses (after instructor filter)
            let totalTrainees = 0;
            selectedCourses.forEach(key => {
                const [code, scheduleType] = key.split('|');
                const count = sf01Data.filter(r =>
                    r['المقرر'] === code &&
                    r['نوع الجدولة'] === scheduleType &&
                    includedStatuses.includes(r['حالة تسجيل'] || 'غير محدد') &&
                    isInstructorIncluded(r)
                ).length;
                totalTrainees += count;
            });
            selectedCourseTraineeCount = totalTrainees;

            // Show selected courses summary with trainee counts
            const summaryEl = document.getElementById('selectedCoursesSummary');
            const coursesList = selectedCourses.map(key => {
                const [code, scheduleType] = key.split('|');
                const course = sf01Data.find(r => r['المقرر'] === code);
                const name = course ? course['اسم المقرر'] : '';
                // Get count for this specific course
                const courseCount = sf01Data.filter(r =>
                    r['المقرر'] === code &&
                    r['نوع الجدولة'] === scheduleType &&
                    includedStatuses.includes(r['حالة تسجيل'] || 'غير محدد') &&
